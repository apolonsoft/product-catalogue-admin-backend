# Backend
PORT=3000
APP_URL=http://localhost:3000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1h
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change-me-in-production
BCRYPT_SALT_ROUNDS=10
INVITE_EXPIRES_IN_DAYS=7
PASSWORD_RESET_EXPIRES_IN_MINUTES=30

# Database
POSTGRES_USER=product_catalogue
POSTGRES_PASSWORD=product_catalogue
POSTGRES_DB=product_catalogue
POSTGRES_PORT=5432
DATABASE_URL=postgres://product_catalogue:product_catalogue@localhost:5432/product_catalogue

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=product-catalogue
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9000/product-catalogue
AVATAR_MAX_BYTES=2097152

# Mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@example.com
